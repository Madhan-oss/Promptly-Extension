{
  "manifest_version": 2,
  "name": "Promptly",
  "version": "1.2.0",
  "description": "Promptly — turn one-line prompts into structured, high-quality prompts for any AI chat. Export full chats when limits hit. No login required.",

  "browser_specific_settings": {
    "gecko": {
      "id": "promptly@extension.dev",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "<all_urls>",
    "https://api.groq.com/*",
    "https://*.vercel.app/*"
  ],

  "commands": {
    "optimize-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Optimize the current prompt with Promptly ⚡"
    }
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "chat-exporter.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "Promptly — Optimize Your Prompts"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "data_collection_permissions": {
    "known_personal_data": [],
    "active_user_telemetry": false
  }
}
